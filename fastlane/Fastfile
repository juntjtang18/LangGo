default_platform(:ios)

platform :ios do
  CERT_REPO_URL = "https://github.com/juntjtang18/LangGo-certificates"

  desc "Create App Store signing certs and profiles"
  lane :setup_signing do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"]
    )

    match(
      type: "appstore",
      git_url: CERT_REPO_URL,
      api_key: api_key
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"]
    )

    match(
      type: "appstore",
      git_url: CERT_REPO_URL,
      readonly: true,
      api_key: api_key
    )

    build_app(
      scheme: "LangGo",
      export_method: "app-store"
    )

    upload_to_testflight(
      api_key: api_key
    )
  end

  desc "Delete old App Store signing from match"
  lane :nuke_signing do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"]
    )

    match_nuke(
      type: "appstore",
      git_url: CERT_REPO_URL,
      api_key: api_key
    )
  end
end