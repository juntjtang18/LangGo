    "What is your native language?" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quelle est votre langue maternelle ?"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी मूल भाषा क्या है?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの母国語は何ですか?"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신의 모국어는 무엇입니까?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ngôn ngữ mẹ đẻ của bạn là gì?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
