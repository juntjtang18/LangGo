    "Nice work! You’ve finished today’s due words." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beau travail ! Vous avez terminé les paroles dues aujourd’hui."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अच्छा काम! आपने आज के नियत शब्द पूरे कर लिए हैं."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "いい仕事だ！今日の期限の言葉を終えました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "잘했어요! 오늘의 할말을 마쳤습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Làm tốt lắm! Bạn đã hoàn thành lời nói của ngày hôm nay."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "做得很好！你已完成今天到期的单词。"
          }
        }
      }
    },
