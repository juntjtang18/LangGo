    "Want to remember 10× more — with less effort?": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "想用更少努力，多记住 10 倍内容吗？"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "少ない労力で 10 倍多くのことを覚えたいですか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "더 적은 노력으로 10배 더 기억하고 싶으신가요?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous voulez mémoriser 10 fois plus, avec moins d'effort ?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn muốn nhớ thêm 10 lần — với ít nỗ lực hơn?"
