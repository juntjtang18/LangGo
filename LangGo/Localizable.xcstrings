        }
      }
    },
    "You have no words due for review.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你没有到期需要复习的单词。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検討すべき言葉はありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "검토할 단어가 없습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous n'avez pas de mots à réviser."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn không có từ nào để xem xét."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "समीक्षा के लिए आपके पास शब्द नहीं हैं."
          }
        }
      }
    },
    "You'll still see the leaderboard, but others won't see your rank or username.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你仍然可以看到排行榜，但其他人看不到你的排名或用户名。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リーダーボードは引き続き表示されますが、他の人にはあなたのランクやユーザー名は表示されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "귀하에게는 리더보드가 계속 표시되지만 다른 사용자에게는 귀하의 순위나 사용자 이름이 표시되지 않습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous verrez toujours le classement, mais les autres ne verront pas votre classement ou votre nom d'utilisateur."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn sẽ vẫn thấy bảng xếp hạng nhưng những người khác sẽ không thấy thứ hạng hoặc tên người dùng của bạn."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप अभी भी लीडरबोर्ड देखेंगे, लेकिन अन्य लोग आपकी रैंक या उपयोगकर्ता नाम नहीं देखेंगे।"
          }
        }
      }
    },
    "Your journey to glory": {
